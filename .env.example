# === CLÉS API ===

# Clé ILaaS AMUE
# Endpoint : https://llm.ilaas.fr/v1 — Modèle : Mistral Medium 3 (accord AMUE)
# Fournie par votre référent numérique via le dispositif AMUE
ILAAS_API_KEY=votre-cle-ilaas-ici

# Option : clé Mistral standard (hors accord AMUE/ILaaS)
# Si vous utilisez mistral.ai directement, décommentez la ligne ci-dessous
# et adaptez litellm_config.yaml (voir les blocs commentés dans ce fichier).
# MISTRAL_API_KEY=votre-cle-mistral-standard-ici

# === LITELLM ===
LITELLM_MASTER_KEY=sk-changez-moi
LITELLM_SECRET_KEY=changez-moi

# === POSTGRESQL ===
POSTGRES_USER=litellm
POSTGRES_PASSWORD=changez-moi
POSTGRES_DB=litellm

# === REDIS ===
REDIS_PASSWORD=changez-moi

# === OPENWEBUI ===
WEBUI_SECRET_KEY=changez-moi
WEBUI_NAME=MyIA — Mon Université
WEBUI_URL=https://chat.votre-etablissement.fr

# === PORTS ===
PORT_OWUI=3000
PORT_LITELLM=4000

# === VOLUMES ===
VOL_DATA_POSTGRES=./data/postgres
VOL_DATA_REDIS=./data/redis
VOL_DATA_OPENWEBUI=./data/openwebui
